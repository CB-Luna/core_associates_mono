# ============================================================
# CORE ASSOCIATES - Variables de Entorno
# ============================================================
# Copia este archivo como .env y ajusta los valores

# ── PostgreSQL ──
DB_USER=core_admin
DB_PASSWORD=core_secret_2026
DB_NAME=core_associates_db
# Conexión desde host: localhost:5435
# Conexión desde Docker: postgres:5432

# ── Redis ──
REDIS_PASSWORD=core_redis_2026
# Conexión desde host: localhost:6382
# Conexión desde Docker: redis:6379

# ── MinIO ──
MINIO_ROOT_USER=core_minio_admin
MINIO_ROOT_PASSWORD=core_minio_secret_2026
# API desde host: localhost:9002
# Console desde host: localhost:9003
# Desde Docker: minio:9000

# ── JWT ──
JWT_SECRET=cambiar_en_produccion_usar_string_aleatorio_64_chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── NextAuth ──
NEXTAUTH_SECRET=cambiar_en_produccion_usar_string_aleatorio_64_chars
NEXTAUTH_URL=http://localhost:3600

# ── Twilio (SMS OTP) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+521XXXXXXXXXX

# ── Firebase (Push Notifications) ──
FIREBASE_PROJECT_ID=core-associates-xxxxx

# ── pgAdmin (opcional, puerto 5056 para no chocar con gen_portales en 5055) ──
PGADMIN_EMAIL=admin@coreassociates.com
PGADMIN_PASSWORD=admin123
