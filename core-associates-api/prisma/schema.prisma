// ============================================================
// CORE ASSOCIATES - Prisma Schema
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ── ENUMS ──

enum EstadoAsociado {
  pendiente
  activo
  suspendido
  baja
  rechazado
}

enum TipoDocumento {
  ine_frente
  ine_reverso
  selfie
  tarjeta_circulacion
  otro
}

enum EstadoDocumento {
  pendiente
  aprobado
  rechazado
}

enum TipoProveedor {
  abogado
  comida
  taller
  lavado
  capacitacion
  otro
}

enum EstadoProveedor {
  activo
  inactivo
}

enum TipoDescuento {
  porcentaje
  monto_fijo
}

enum EstadoPromocion {
  activa
  pausada
  finalizada
}

enum EstadoCupon {
  activo
  canjeado
  vencido
  cancelado
}

enum TipoPercance {
  accidente
  infraccion
  robo
  asalto
  otro
}

enum EstadoCasoLegal {
  abierto
  en_atencion
  escalado
  resuelto
  cerrado
  cancelado
}

enum PrioridadCaso {
  baja
  media
  alta
  urgente
}

enum RolUsuario {
  admin
  operador
  proveedor
  abogado
}

enum EstadoUsuario {
  activo
  inactivo
}

enum TipoMenu {
  enlace
  seccion
  separador
}

// ── MODELOS ──

model ModuloMenu {
  id        String    @id @default(uuid()) @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid
  codigo    String    @unique @db.VarChar(50)
  titulo    String    @db.VarChar(100)
  ruta      String?   @db.VarChar(200)
  icono     String?   @db.VarChar(50) // Nombre de ícono Lucide
  permisos  String[]  @default([]) // Roles con acceso: admin, operador, proveedor
  orden     Int       @default(0)
  tipo      TipoMenu  @default(enlace)
  visible   Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Self-referencial
  parent    ModuloMenu?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children  ModuloMenu[] @relation("MenuHierarchy")

  // Relación M:N con Roles
  rolMenuItems  RolModuloMenu[]

  @@index([parentId])
  @@index([orden])
  @@map("modulos_menu")
}

model Asociado {
  id               String          @id @default(uuid()) @db.Uuid
  idUnico          String          @unique @map("id_unico") @db.VarChar(20)
  nombre           String?         @db.VarChar(100)
  apellidoPat      String?         @map("apellido_pat") @db.VarChar(100)
  apellidoMat      String?         @map("apellido_mat") @db.VarChar(100)
  telefono         String          @unique @db.VarChar(15)
  email            String?         @db.VarChar(150)
  fechaNacimiento  DateTime?       @map("fecha_nacimiento") @db.Date
  fotoUrl          String?         @map("foto_url") @db.VarChar(500)
  estado           EstadoAsociado  @default(pendiente)
  motivoRechazo    String?         @map("motivo_rechazo")
  fechaRegistro    DateTime        @default(now()) @map("fecha_registro")
  fechaAprobacion  DateTime?       @map("fecha_aprobacion")
  aprobadoPorId    String?         @map("aprobado_por") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  // Relaciones
  aprobadoPor      Usuario?        @relation("AprobadorAsociado", fields: [aprobadoPorId], references: [id])
  vehiculos        Vehiculo[]
  documentos       Documento[]
  cupones          Cupon[]
  casosLegales     CasoLegal[]
  dispositivos     DispositivoToken[]
  notas            NotaAsociado[]
  intentosDocumento IntentoDocumento[]

  @@index([estado])
  @@index([telefono])
  @@map("asociados")
}

model Vehiculo {
  id           String   @id @default(uuid()) @db.Uuid
  asociadoId   String   @map("asociado_id") @db.Uuid
  marca        String   @db.VarChar(50)
  modelo       String   @db.VarChar(50)
  anio         Int
  color        String   @db.VarChar(30)
  placas       String   @db.VarChar(15)
  numeroSerie  String?  @map("numero_serie") @db.VarChar(50)
  fotoUrl      String?  @map("foto_url") @db.VarChar(500)
  esPrincipal  Boolean  @default(true) @map("es_principal")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relaciones
  asociado     Asociado @relation(fields: [asociadoId], references: [id], onDelete: Cascade)

  @@unique([placas])
  @@map("vehiculos")
}

model Documento {
  id             String          @id @default(uuid()) @db.Uuid
  asociadoId     String          @map("asociado_id") @db.Uuid
  tipo           TipoDocumento
  s3Bucket       String          @map("s3_bucket") @db.VarChar(100)
  s3Key          String          @map("s3_key") @db.VarChar(500)
  contentType    String          @map("content_type") @db.VarChar(50)
  fileSize       Int             @map("file_size")
  checksumSha256 String?         @map("checksum_sha256") @db.VarChar(64)
  estado         EstadoDocumento @default(pendiente)
  motivoRechazo  String?         @map("motivo_rechazo")
  revisadoPorId  String?         @map("revisado_por") @db.Uuid
  fechaRevision  DateTime?       @map("fecha_revision")
  createdAt      DateTime        @default(now()) @map("created_at")

  // Relaciones
  asociado       Asociado        @relation(fields: [asociadoId], references: [id], onDelete: Cascade)
  revisadoPor    Usuario?        @relation("RevisadorDocumento", fields: [revisadoPorId], references: [id])
  analisis       AnalisisDocumento?

  @@map("documentos")
}

// ── AI Document Analysis ──

enum EstadoAnalisis {
  procesando
  completado
  error
}

model AnalisisDocumento {
  id              String         @id @default(uuid()) @db.Uuid
  documentoId     String         @unique @map("documento_id") @db.Uuid
  provider        String         @db.VarChar(50)
  modelo          String         @db.VarChar(100)
  estado          EstadoAnalisis @default(procesando)
  datosExtraidos  Json?          @map("datos_extraidos")
  confianza       Float?
  validaciones    Json?
  errorMsg        String?        @map("error_msg")
  tokensUsados    Int?           @map("tokens_usados")
  tiempoMs        Int?           @map("tiempo_ms")
  createdAt       DateTime       @default(now()) @map("created_at")

  documento       Documento      @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@map("analisis_documentos")
}

model ConfiguracionIA {
  id              String   @id @default(uuid()) @db.Uuid
  clave           String   @unique @db.VarChar(50)
  nombre          String   @db.VarChar(100)
  provider        String   @db.VarChar(50)
  modelo          String   @db.VarChar(100)
  apiKey          String?  @map("api_key") @db.VarChar(500)
  promptSistema   String?  @map("prompt_sistema")
  temperatura     Float    @default(0.3)
  maxTokens       Int      @default(4096) @map("max_tokens")
  activo          Boolean  @default(true)

  // Umbrales de auto-decisión y anti-troll (configurables desde CRM Conf AI)
  umbralAutoAprobacion  Float  @default(0.90) @map("umbral_auto_aprobacion")
  umbralAutoRechazo     Float  @default(0.40) @map("umbral_auto_rechazo")
  maxRechazosPreval     Int    @default(5)    @map("max_rechazos_preval")
  horasBloqueoPreval    Int    @default(24)   @map("horas_bloqueo_preval")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("configuracion_ia")
}

// ── Intentos de pre-validación (anti-troll) ──

model IntentoDocumento {
  id              String        @id @default(uuid()) @db.Uuid
  asociadoId      String        @map("asociado_id") @db.Uuid
  tipo            TipoDocumento
  resultado       String        @db.VarChar(20) // 'aprobado' | 'rechazado'
  motivoRechazo   String?       @map("motivo_rechazo")
  createdAt       DateTime      @default(now()) @map("created_at")

  asociado        Asociado      @relation(fields: [asociadoId], references: [id], onDelete: Cascade)

  @@map("intentos_documentos")
}

model Proveedor {
  id              String          @id @default(uuid()) @db.Uuid
  idUnico         String          @unique @map("id_unico") @db.VarChar(20)
  razonSocial     String          @map("razon_social") @db.VarChar(200)
  tipo            TipoProveedor
  direccion       String?
  latitud         Decimal?        @db.Decimal(10, 8)
  longitud        Decimal?        @db.Decimal(11, 8)
  telefono        String?         @db.VarChar(15)
  email           String?         @db.VarChar(150)
  logotipoUrl     String?         @map("logotipo_url") @db.VarChar(500)
  contactoNombre  String?         @map("contacto_nombre") @db.VarChar(100)
  estado          EstadoProveedor @default(activo)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relaciones
  promociones     Promocion[]
  cuponesEmitidos Cupon[]         @relation("CuponProveedor")
  cuponesCanjeados Cupon[]        @relation("CuponCanjeadoPor")
  casosLegales    CasoLegal[]
  usuarios        Usuario[]

  @@index([tipo])
  @@map("proveedores")
}

model Promocion {
  id              String          @id @default(uuid()) @db.Uuid
  proveedorId     String          @map("proveedor_id") @db.Uuid
  titulo          String          @db.VarChar(200)
  descripcion     String
  tipoDescuento   TipoDescuento   @map("tipo_descuento")
  valorDescuento  Decimal         @map("valor_descuento") @db.Decimal(10, 2)
  fechaInicio     DateTime        @map("fecha_inicio") @db.Date
  fechaFin        DateTime        @map("fecha_fin") @db.Date
  vigenciaCupon   Int             @map("vigencia_cupon") // horas
  terminos        String?
  imagenUrl       String?         @map("imagen_url") @db.VarChar(500)
  maxCupones      Int?            @map("max_cupones")
  estado          EstadoPromocion @default(activa)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relaciones
  proveedor       Proveedor       @relation(fields: [proveedorId], references: [id])
  cupones         Cupon[]

  @@map("promociones")
}

model Cupon {
  id                String      @id @default(uuid()) @db.Uuid
  codigo            String      @unique @db.VarChar(30)
  asociadoId        String      @map("asociado_id") @db.Uuid
  promocionId       String      @map("promocion_id") @db.Uuid
  proveedorId       String      @map("proveedor_id") @db.Uuid
  qrPayload         String      @map("qr_payload")
  qrFirma           String      @map("qr_firma") @db.VarChar(128)
  estado            EstadoCupon @default(activo)
  fechaGeneracion   DateTime    @map("fecha_generacion")
  fechaVencimiento  DateTime    @map("fecha_vencimiento")
  fechaCanje        DateTime?   @map("fecha_canje")
  canjeadoPorId     String?     @map("canjeado_por") @db.Uuid
  createdAt         DateTime    @default(now()) @map("created_at")

  // Relaciones
  asociado          Asociado    @relation(fields: [asociadoId], references: [id])
  promocion         Promocion   @relation(fields: [promocionId], references: [id])
  proveedor         Proveedor   @relation("CuponProveedor", fields: [proveedorId], references: [id])
  canjeadoPor       Proveedor?  @relation("CuponCanjeadoPor", fields: [canjeadoPorId], references: [id])

  @@index([estado])
  @@index([asociadoId])
  @@index([proveedorId])
  @@index([fechaVencimiento])
  @@map("cupones")
}

model CasoLegal {
  id                String           @id @default(uuid()) @db.Uuid
  codigo            String           @unique @db.VarChar(30)
  asociadoId        String           @map("asociado_id") @db.Uuid
  abogadoId         String?          @map("abogado_id") @db.Uuid
  abogadoUsuarioId  String?          @map("abogado_usuario_id") @db.Uuid
  tipoPercance      TipoPercance     @map("tipo_percance")
  descripcion       String?
  latitud           Decimal          @db.Decimal(10, 8)
  longitud          Decimal          @db.Decimal(11, 8)
  direccionAprox    String?          @map("direccion_aprox")
  estado            EstadoCasoLegal  @default(abierto)
  prioridad         PrioridadCaso    @default(media)
  fechaApertura     DateTime         @default(now()) @map("fecha_apertura")
  fechaAsignacion   DateTime?        @map("fecha_asignacion")
  fechaCierre       DateTime?        @map("fecha_cierre")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relaciones
  asociado          Asociado         @relation(fields: [asociadoId], references: [id])
  abogado           Proveedor?       @relation(fields: [abogadoId], references: [id])
  abogadoUsuario    Usuario?         @relation("AbogadoCasoLegal", fields: [abogadoUsuarioId], references: [id])
  notas             NotaCaso[]
  documentos        DocumentoCaso[]

  @@index([estado])
  @@index([abogadoUsuarioId])
  @@map("casos_legales")
}

model NotaCaso {
  id        String   @id @default(uuid()) @db.Uuid
  casoId    String   @map("caso_id") @db.Uuid
  autorId   String   @map("autor_id") @db.Uuid
  contenido String
  esPrivada Boolean  @default(false) @map("es_privada")
  createdAt DateTime @default(now()) @map("created_at")

  // Relaciones
  caso      CasoLegal @relation(fields: [casoId], references: [id], onDelete: Cascade)
  autor     Usuario   @relation(fields: [autorId], references: [id])

  @@map("notas_caso")
}

model DocumentoCaso {
  id           String   @id @default(uuid()) @db.Uuid
  casoId       String   @map("caso_id") @db.Uuid
  nombre       String   @db.VarChar(255)
  s3Bucket     String   @map("s3_bucket") @db.VarChar(100)
  s3Key        String   @map("s3_key") @db.VarChar(500)
  contentType  String   @map("content_type") @db.VarChar(50)
  fileSize     Int      @map("file_size")
  subidoPorId  String   @map("subido_por_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  // Relaciones
  caso         CasoLegal @relation(fields: [casoId], references: [id], onDelete: Cascade)
  subidoPor    Usuario   @relation("SubidorDocumentoCaso", fields: [subidoPorId], references: [id])

  @@index([casoId])
  @@map("documentos_caso")
}

model Usuario {
  id            String        @id @default(uuid()) @db.Uuid
  email         String        @unique @db.VarChar(150)
  passwordHash  String        @map("password_hash") @db.VarChar(255)
  nombre        String        @db.VarChar(100)
  rol           RolUsuario
  rolId         String?       @map("rol_id") @db.Uuid
  proveedorId   String?       @map("proveedor_id") @db.Uuid
  avatarUrl     String?       @map("avatar_url") @db.VarChar(255)
  especialidad  String?       @db.VarChar(100)
  temaId        String?       @map("tema_id") @db.Uuid
  estado        EstadoUsuario @default(activo)
  ultimoAcceso  DateTime?     @map("ultimo_acceso")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relaciones
  rolRef               Rol?        @relation(fields: [rolId], references: [id])
  proveedor            Proveedor?  @relation(fields: [proveedorId], references: [id])
  tema                 Tema?       @relation("TemaAsignado", fields: [temaId], references: [id], onDelete: SetNull)
  temasCreados         Tema[]      @relation("TemaCreador")
  asociadosAprobados   Asociado[]  @relation("AprobadorAsociado")
  documentosRevisados  Documento[] @relation("RevisadorDocumento")
  notasCaso            NotaCaso[]
  documentosCasoSubidos DocumentoCaso[] @relation("SubidorDocumentoCaso")
  notasAsociado        NotaAsociado[]
  auditorias           Auditoria[]
  casosComoAbogado     CasoLegal[] @relation("AbogadoCasoLegal")
  dispositivoTokens    DispositivoToken[]
  notificacionesCrm    NotificacionCRM[]

  @@map("usuarios")
}

model Auditoria {
  id               String   @id @default(uuid()) @db.Uuid
  usuarioId        String?  @map("usuario_id") @db.Uuid
  accion           String   @db.VarChar(50)
  entidad          String   @db.VarChar(50)
  entidadId        String   @map("entidad_id") @db.Uuid
  datosAnteriores  Json?    @map("datos_anteriores")
  datosNuevos      Json?    @map("datos_nuevos")
  ip               String?  @db.VarChar(45)
  createdAt        DateTime @default(now()) @map("created_at")

  // Relaciones
  usuario          Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("auditoria")
}

model DispositivoToken {
  id           String    @id @default(uuid()) @db.Uuid
  asociadoId   String?   @map("asociado_id") @db.Uuid
  usuarioId    String?   @map("usuario_id") @db.Uuid
  token        String    @db.VarChar(500)
  plataforma   String    @db.VarChar(10) // android | ios
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relaciones
  asociado     Asociado? @relation(fields: [asociadoId], references: [id], onDelete: Cascade)
  usuario      Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([asociadoId])
  @@index([usuarioId])
  @@map("dispositivos_token")
}

model NotaAsociado {
  id           String   @id @default(uuid()) @db.Uuid
  asociadoId   String   @map("asociado_id") @db.Uuid
  autorId      String   @map("autor_id") @db.Uuid
  contenido    String
  tipo         String   @default("nota") @db.VarChar(30) // nota | cambio_estado
  metadatos    Json?    // Para cambio_estado: { estadoAnterior, estadoNuevo, motivo }
  createdAt    DateTime @default(now()) @map("created_at")

  // Relaciones
  asociado     Asociado @relation(fields: [asociadoId], references: [id], onDelete: Cascade)
  autor        Usuario  @relation(fields: [autorId], references: [id])

  @@index([asociadoId])
  @@map("notas_asociado")
}

model ResumenDiario {
  id                    String   @id @default(uuid()) @db.Uuid
  fecha                 DateTime @unique @db.Date
  casosNuevos           Int      @default(0) @map("casos_nuevos")
  casosEnAtencion       Int      @default(0) @map("casos_en_atencion")
  casosResueltos        Int      @default(0) @map("casos_resueltos")
  casosTotalAbiertos    Int      @default(0) @map("casos_total_abiertos")
  asociadosRegistrados  Int      @default(0) @map("asociados_registrados")
  cuponesGenerados      Int      @default(0) @map("cupones_generados")
  cuponesCanjeados      Int      @default(0) @map("cupones_canjeados")
  docsPendientes        Int      @default(0) @map("docs_pendientes")
  createdAt             DateTime @default(now()) @map("created_at")

  @@map("resumenes_diarios")
}

model Tema {
  id         String   @id @default(uuid()) @db.Uuid
  nombre     String   @db.VarChar(100)
  categoria  String?  @db.VarChar(50)   // Sección de agrupación: CORPORATIVO, ESTILOS, etc.
  colores    Json     // ThemeConfig JSON (primary, secondary, accent, etc.)
  fuente     String?  @db.VarChar(100)  // font-family
  logoUrl    String?  @map("logo_url") @db.VarChar(255)
  esGlobal   Boolean  @default(false) @map("es_global")
  creadoPor  String   @map("creado_por") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relaciones
  creador    Usuario  @relation("TemaCreador", fields: [creadoPor], references: [id])
  usuarios   Usuario[] @relation("TemaAsignado")
  rolesDefecto Rol[]  @relation("TemaRolDefecto")

  @@map("temas")
}

// ── RBAC: Roles y Permisos Dinámicos ──

model NotificacionCRM {
  id              String   @id @default(uuid()) @db.Uuid
  usuarioId       String   @map("usuario_id") @db.Uuid
  titulo          String   @db.VarChar(200)
  mensaje         String
  tipo            String   @db.VarChar(50)       // caso_asignado | nota_nueva | estado_cambio | general
  referenciaId    String?  @map("referencia_id") @db.Uuid
  referenciaTipo  String?  @map("referencia_tipo") @db.VarChar(50) // caso_legal | asociado
  leida           Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leida])
  @@index([createdAt])
  @@map("notificaciones_crm")
}

model Rol {
  id                String       @id @default(uuid()) @db.Uuid
  nombre            String       @unique @db.VarChar(50)
  descripcion       String?      @db.VarChar(200)
  icono             String?      @db.VarChar(50)   // Nombre de ícono Lucide
  color             String?      @db.VarChar(20)   // Color hex: #3B82F6
  esProtegido       Boolean      @default(false) @map("es_protegido")
  esPorDefecto      Boolean      @default(false) @map("es_por_defecto") // Rol asignado automáticamente a nuevos usuarios
  temaIdPorDefecto  String?      @map("tema_id_por_defecto") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  // Relaciones
  temaPorDefecto Tema?        @relation("TemaRolDefecto", fields: [temaIdPorDefecto], references: [id], onDelete: SetNull)
  permisos       RolPermiso[]
  menuItems      RolModuloMenu[]
  usuarios       Usuario[]

  @@map("roles")
}

model RolModuloMenu {
  rolId         String   @map("rol_id") @db.Uuid
  moduloMenuId  String   @map("modulo_menu_id") @db.Uuid
  orden         Int      @default(0)

  // Relaciones
  rol           Rol         @relation(fields: [rolId], references: [id], onDelete: Cascade)
  moduloMenu    ModuloMenu  @relation(fields: [moduloMenuId], references: [id], onDelete: Cascade)

  @@id([rolId, moduloMenuId])
  @@map("roles_modulos_menu")
}

model Permiso {
  id           String       @id @default(uuid()) @db.Uuid
  codigo       String       @unique @db.VarChar(100)
  grupo        String       @db.VarChar(50)
  descripcion  String?      @db.VarChar(200)
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relaciones
  roles        RolPermiso[]

  @@index([grupo])
  @@map("permisos")
}

model RolPermiso {
  rolId      String   @map("rol_id") @db.Uuid
  permisoId  String   @map("permiso_id") @db.Uuid

  // Relaciones
  rol        Rol      @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso    Permiso  @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("roles_permisos")
}
