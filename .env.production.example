# ============================================================
# CORE ASSOCIATES - Variables de Entorno PRODUCCION
# ============================================================
# Copia este archivo como .env en el servidor y ajusta TODOS los valores.
# NO usar los defaults de desarrollo.
#
# Uso:
#   cp .env.production.example .env
#   nano .env
# ============================================================

# ── Servidor (IP o dominio) ──
# Estas URLs son las que usa el BROWSER del usuario para llegar a tus servicios.
# Cambia la IP por tu dominio cuando lo tengas.
SERVER_HOST=216.250.125.239
NEXT_PUBLIC_API_URL=http://216.250.125.239:3501
NEXT_PUBLIC_MINIO_URL=http://216.250.125.239:9002
NEXTAUTH_URL=http://216.250.125.239:3600
MINIO_PUBLIC_URL=http://216.250.125.239:9002

# ── PostgreSQL ──
DB_USER=core_admin
DB_PASSWORD=CAMBIAR_password_seguro_aqui_32chars
DB_NAME=core_associates_db

# ── Redis ──
REDIS_PASSWORD=CAMBIAR_redis_password_seguro_aqui

# ── MinIO ──
MINIO_ROOT_USER=CAMBIAR_minio_admin_user
MINIO_ROOT_PASSWORD=CAMBIAR_minio_password_seguro_aqui

# ── JWT (generar con: openssl rand -hex 32) ──
JWT_SECRET=CAMBIAR_generar_con_openssl_rand_hex_32
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── NextAuth (generar con: openssl rand -hex 32) ──
NEXTAUTH_SECRET=CAMBIAR_generar_con_openssl_rand_hex_32

# ── Twilio (SMS OTP) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+521XXXXXXXXXX

# ── Firebase Admin SDK (Push Notifications — FCM HTTP v1) ──
# Opción 1: Ruta al archivo JSON de service account
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Opción 2: JSON de service account en base64 (ideal para Docker/CI)
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# ── pgAdmin (NO incluido en produccion por defecto) ──
# Solo se levanta con: docker compose --profile tools up pgadmin
PGADMIN_EMAIL=admin@coreassociates.com
PGADMIN_PASSWORD=CAMBIAR_pgadmin_password
